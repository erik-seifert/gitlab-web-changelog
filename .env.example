# Chrome Web Store credentials
# Copy to .env and fill in the values (never commit .env)

# Found in the Chrome Web Store Developer Dashboard URL:
# https://chrome.google.com/webstore/devconsole/<EXTENSION_ID>
CHROME_EXTENSION_ID=

# OAuth2 credentials from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client IDs)
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=

# One-time token obtained via the OAuth2 flow:
# https://github.com/nicedoc/chrome-webstore-upload#setup
CHROME_REFRESH_TOKEN=
