{
  "manifest_version": 3,
  "name": "GitLab Changelog Generator",
  "version": "1.4.0",
  "description": "Generates a changelog between two GitLab tags, including all linked issues. Works with self-hosted GitLab instances.",
  "permissions": ["storage", "scripting"],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "GitLab Changelog Generator",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
